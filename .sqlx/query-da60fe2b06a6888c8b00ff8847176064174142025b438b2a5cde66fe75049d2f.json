  "query": "SELECT DISTINCT r.id, r.name, r.repo_path, r.ssh_user, r.ssh_host, r.ssh_port, r.compression, r.encryption, r.enabled, r.owner_id, r.visibility, r.sync_schedule FROM repos r JOIN schedules s ON s.repo_id = r.id JOIN schedule_targets st ON st.schedule_id = s.id WHERE st.agent_id = $1 ORDER BY r.id",
