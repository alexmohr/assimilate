# Stage 1: Build Rust agent binary
FROM rust:1.87-trixie AS rust-builder
WORKDIR /app
RUN rustup default nightly

COPY Cargo.toml Cargo.lock ./
COPY crates/ crates/
RUN cargo build --release -p agent

# Stage 2: Runtime
FROM debian:trixie-slim
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    libssl3 \
    borgbackup \
    openssh-client \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY --from=rust-builder /app/target/release/agent /app/agent

ENTRYPOINT ["/app/agent"]
