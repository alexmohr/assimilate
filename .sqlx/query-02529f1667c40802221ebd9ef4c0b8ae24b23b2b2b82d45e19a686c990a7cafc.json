  "query": "\n        INSERT INTO push_subscriptions (user_id, endpoint, p256dh, auth, created_at)\n        VALUES ($1, $2, $3, $4, NOW())\n        ON CONFLICT (endpoint) DO UPDATE SET p256dh = $3, auth = $4\n        RETURNING id, user_id, endpoint, p256dh, auth, user_agent, created_at\n        ",
